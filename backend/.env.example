# Server Configuration
PORT=8080

# MongoDB Connection
# Railway and most Node deploy platforms commonly use MONGO_URI.
# MONGO_URL is also supported by app.js for backward compatibility.
MONGO_URI=mongodb://localhost:27017/rtcrs

# JWT Secret (use a strong random string for production)
JWT_SECRET=your_super_secret_jwt_key_here

# Email Configuration (for sending notifications)
EMAIL=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Cloudinary Configuration (IMPORTANT - Fix for your API key error)
# Get these from your Cloudinary Dashboard: https://cloudinary.com/users/sign_in
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

